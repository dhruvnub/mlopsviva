pipeline {
    agent any

    stages {
        stage('Install') {
            steps {
                sh 'pip install scikit-learn'
            }
        }
        stage('Train') {
            steps {
                sh 'python src/train.py'
            }
        }
        
    }

    post {
        success { echo 'Pipeline passed!' }
        failure { echo 'Pipeline failed.' }
    }
}